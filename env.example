# Optional: Forgot Password (email-based reset)
# Copy to .env and set values, or set in the environment.

# Public URL of the app (used in reset link emails).
# Production (IIS + HTTPS): https://fuel.yourcompany.com
# Dev (Vite): http://localhost:5173
# LAN mode: http://SERVER-IP:8000
APP_BASE_URL=http://localhost:5173

# Session cookie Secure flag (optional; auto-set when APP_BASE_URL is https://)
# SESSION_COOKIE_SECURE=true

# CORS origins (comma-separated; APP_BASE_URL is added automatically)
# Add your Vercel URL when using Vercel frontend + on-prem API:
# CORS_ORIGINS=http://localhost:5173,https://frontend-lovat-beta-54.vercel.app

# Vercel only — proxy /api/* to your public FastAPI URL (set in Vercel dashboard too)
# API_PROXY_URL=https://your-public-api-host

# SMTP (for sending reset emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true
