# Optional: Forgot Password (email-based reset)
# Copy to .env and set values, or set in the environment.

# Base URL of the app (used in reset link emails). Example: http://localhost:8501
APP_BASE_URL=http://localhost:8501

# SMTP (for sending reset emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true
